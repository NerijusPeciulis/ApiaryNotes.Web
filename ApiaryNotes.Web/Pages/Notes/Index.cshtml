@page
@model ApiaryNotes.Web.Pages.Notes.IndexModel
@{
    ViewData["Title"] = "Užrašai";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h1 class="mb-0">
        Užrašai: @Model.ApiaryName / @Model.HiveCode
    </h1>

    <div>
        <a class="btn btn-success"
           asp-page="Create"
           asp-route-apiaryId="@Model.ApiaryId"
           asp-route-hiveId="@Model.HiveId">
            + Naujas užrašas
        </a>

        <a class="btn btn-outline-secondary"
           asp-page="/Hives/Index"
           asp-route-apiaryId="@Model.ApiaryId">
            Atgal
        </a>
    </div>
</div>

<form method="get" class="row g-2 mb-3">
    <input type="hidden" name="apiaryId" value="@Model.ApiaryId" />
    <input type="hidden" name="hiveId" value="@Model.HiveId" />

    <div class="col-md-6">
        <input class="form-control"
               name="search"
               value="@Model.Search"
               placeholder="🔍 Ieškoti užrašuose..." />
    </div>

    <div class="col-auto">
        <button class="btn btn-primary">Ieškoti</button>

        <a class="btn btn-outline-secondary"
           asp-page="Index"
           asp-route-apiaryId="@Model.ApiaryId"
           asp-route-hiveId="@Model.HiveId">
            Išvalyti
        </a>
    </div>
</form>

@if (Model.Notes.Count == 0)
{
    <p>Kol kas nėra užrašų.</p>
}
else
{
    <div class="table-responsive">
<table class="table table-striped table-hover">
        <thead>
            <tr>
                <th>Data</th>
                <th>Pavadinimas</th>
                <th>Tekstas</th>
                <th></th>
            </tr>
        </thead>
        <tbody>
            @foreach (var n in Model.Notes)
            {
                <tr>
                    <td>@n.Date</td>
                    <td>@(string.IsNullOrWhiteSpace(n.Title) ? "-" : n.Title)</td>
                    <td>@(n.Text.Length > 60 ? n.Text.Substring(0, 60) + "..." : n.Text)</td>
                    <td class="text-end">
                        <a class="btn btn-sm btn-outline-secondary"
                           asp-page="Edit"
                           asp-route-id="@n.Id"
                           asp-route-apiaryId="@Model.ApiaryId"
                           asp-route-hiveId="@Model.HiveId">Redaguoti</a>

                        <a class="btn btn-sm btn-outline-danger"
                           asp-page="Delete"
                           asp-route-id="@n.Id"
                           asp-route-apiaryId="@Model.ApiaryId"
                           asp-route-hiveId="@Model.HiveId">Trinti</a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
    </div>
}