@page
@model ApiaryNotes.Web.Pages.Harvest.IndexModel
@{
    ViewData["Title"] = "Produktai";
}

<div class="d-flex justify-content-between align-items-start mb-3 flex-wrap gap-3">
    <div>
        <h2 class="mb-1">Produktai</h2>
        <div class="text-muted">
            Bitynas: <strong>@Model.ApiaryName</strong> |
            Avilys: <strong>@Model.HiveCode</strong>
        </div>
    </div>

    <div class="d-flex gap-2 flex-wrap">
        <a class="btn btn-success"
           asp-page="Create"
           asp-route-apiaryId="@Model.ApiaryId"
           asp-route-hiveId="@Model.HiveId"
           asp-route-year="@Model.SelectedYear">
            + Pridėti
        </a>

        <a class="btn btn-outline-primary"
           asp-page="/Harvest/ApiaryStats"
           asp-route-apiaryId="@Model.ApiaryId"
           asp-route-year="@Model.SelectedYear">
            Bityno statistika
        </a>

        <a class="btn btn-outline-secondary"
           asp-page="/Notes/Index"
           asp-route-apiaryId="@Model.ApiaryId"
           asp-route-hiveId="@Model.HiveId">
            Užrašai
        </a>

        <a class="btn btn-outline-secondary"
           asp-page="/Hives/Index"
           asp-route-apiaryId="@Model.ApiaryId">
            Atgal
        </a>
    </div>
</div>

<form method="get" class="row g-2 align-items-end mb-3">
    <input type="hidden" name="apiaryId" value="@Model.ApiaryId" />
    <input type="hidden" name="hiveId" value="@Model.HiveId" />

    <div class="col-auto">
        <label for="year" class="form-label">Metai</label>
        <select id="year" name="year" class="form-select">
            @foreach (var year in Model.AvailableYears)
            {
                if (year == Model.SelectedYear)
                {
                    <option value="@year" selected>@year</option>
                }
                else
                {
                    <option value="@year">@year</option>
                }
            }
        </select>
    </div>

    <div class="col-auto">
        <button type="submit" class="btn btn-primary">Rodyti</button>
    </div>
</form>

<div class="alert alert-success mb-3">
    <strong>@Model.SelectedYear m. Viso produktų iš šio avilio:</strong>
    @Model.TotalKg.ToString("0.##") kg / @Model.TotalL.ToString("0.##") l
</div>

@if (Model.TotalKg > 0)
{
    <div class="alert alert-light border">
        Iš avilio <strong>@Model.HiveCode</strong> per <strong>@Model.SelectedYear</strong> metus išimta
        <strong>@Model.TotalKg.ToString("0.##") kg</strong>.
    </div>
}

@if (Model.TotalL > 0)
{
    <div class="alert alert-light border">
        Iš avilio <strong>@Model.HiveCode</strong> per <strong>@Model.SelectedYear</strong> metus išimta
        <strong>@Model.TotalL.ToString("0.##") l</strong>.
    </div>
}

@if (Model.Items.Count == 0)
{
    <div class="alert alert-warning">
        Pasirinktais metais medaus išėmimų nėra.
    </div>
}
else
{
    <div class="table-responsive">
        <table class="table table-hover align-middle">
            <thead>
                <tr>
                    <th>Data</th>
                    <th>Kiekis</th>
                    <th>Vienetas</th>
                    <th>Pastaba</th>
                    <th class="text-end"></th>
                </tr>
            </thead>
            <tbody>
                @foreach (var x in Model.Items)
                {
                    <tr>
                        <td>@x.Date.ToString("yyyy-MM-dd")</td>
                        <td>@x.Amount.ToString("0.##")</td>
                        <td>@x.Unit</td>
                        <td>@(string.IsNullOrWhiteSpace(x.Note) ? "-" : x.Note)</td>
                        <td class="text-end">
                            <a class="btn btn-sm btn-outline-secondary"
                               asp-page="Edit"
                               asp-route-id="@x.Id"
                               asp-route-apiaryId="@Model.ApiaryId"
                               asp-route-hiveId="@Model.HiveId"
                               asp-route-year="@Model.SelectedYear">
                                Redaguoti
                            </a>

                            <a class="btn btn-sm btn-outline-danger"
                               asp-page="Delete"
                               asp-route-id="@x.Id"
                               asp-route-apiaryId="@Model.ApiaryId"
                               asp-route-hiveId="@Model.HiveId"
                               asp-route-year="@Model.SelectedYear">
                                Trinti
                            </a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}