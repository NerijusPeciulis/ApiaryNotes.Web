@page
@model ApiaryNotes.Web.Pages.Harvest.CreateModel
@{
    ViewData["Title"] = "Pridėti produktą";
}

<h1>Pridėti produktą (@Model.ApiaryName / @Model.HiveCode)</h1>

<form method="post">
    <div class="text-danger" asp-validation-summary="All"></div>

    <input type="hidden" asp-for="ApiaryId" />
    <input type="hidden" asp-for="HiveId" />

    <div class="mb-3">
        <label class="form-label">Data</label>
        <input class="form-control" asp-for="Input.Date" type="date" />
    </div>

    <div class="mb-3">
        <label class="form-label">Produktas</label>
        <select class="form-select"
                asp-for="Input.Product"
                asp-items="Html.GetEnumSelectList<ApiaryNotes.Web.Domain.ProductType>()">
        </select>
    </div>

    <div class="mb-3">
        <label class="form-label">Kiekis</label>
        <input class="form-control" asp-for="Input.Amount" type="number" step="0.1" />
        <span class="text-danger" asp-validation-for="Input.Amount"></span>
    </div>

    <div class="mb-3">
        <label class="form-label">Vienetas</label>
        <select class="form-select" asp-for="Input.Unit" asp-items="Html.GetEnumSelectList<ApiaryNotes.Web.Domain.HarvestUnit>()"></select>
    </div>

    <div class="mb-3">
        <label class="form-label">Pastaba</label>
        <input class="form-control" asp-for="Input.Note" />
    </div>

    <button class="btn btn-primary" type="submit">Išsaugoti</button>
    <a class="btn btn-secondary" asp-page="Index" asp-route-apiaryId="@Model.ApiaryId" asp-route-hiveId="@Model.HiveId">Atgal</a>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}